{
  "name": "@kui-ui/react",
  "version": "1.0.0",
  "description": "A clean, accessible React UI component library inspired by KRDS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin.d.ts",
        "default": "./dist/plugin.js"
      },
      "require": {
        "types": "./dist/plugin.d.cts",
        "default": "./dist/plugin.cjs"
      }
    },
    "./registry": "./dist/registry.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build && node scripts/build-registry.js",
    "build:dts": "dts-bundle-generator -o dist/index.d.ts src/index.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "dts-bundle-generator": "^9.0.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "@vitejs/plugin-react": "^4.2.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "keywords": [
    "krds",
    "korea",
    "government",
    "design-system",
    "react",
    "tailwindcss",
    "ui",
    "accessibility"
  ],
  "license": "MIT",
  "author": "kysclient <kysclient@gmail.com>",
  "homepage": "https://k-ui-theta.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/kysclient/k-ui"
  },
  "bugs": {
    "url": "https://github.com/kysclient/k-ui/issues"
  }
}
